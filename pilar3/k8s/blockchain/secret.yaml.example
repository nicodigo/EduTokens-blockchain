# Blockchain Secret — credenciales y claves
# ⚠️  RENOMBRAR a secret.yaml y completar los valores reales antes de aplicar.
apiVersion: v1
kind: Secret
metadata:
  name: blockchain-secret
  namespace: blockchain
  labels:
    app: blockchain
type: Opaque
stringData:
  # Conexión AMQP interna (sin TLS) — NCT y Pool están en el mismo cluster que RabbitMQ
  RABBITMQ_URL: "amqp://admin:CHANGE_ME@rabbitmq.infra.svc.cluster.local:5672/"
  # Redis interno
  REDIS_URL: "redis://redis.infra.svc.cluster.local:6379"
  # Ed25519 public key de la autoridad (64 caracteres hex)
  AUTHORITY_PUBKEY: "CHANGE_ME_64_CHAR_ED25519_PUBLIC_KEY"
