# PostgreSQL Secret — template (NO completar con valores reales aquí)
# Copiar a postgres-secret.yaml y completar los valores antes de deployar.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: apps
  labels:
    app: postgres
type: Opaque
stringData:
  POSTGRES_USER: "{{ POSTGRES_USER }}"
  POSTGRES_PASSWORD: "{{ POSTGRES_PASSWORD }}"
  POSTGRES_DB: "{{ POSTGRES_DB }}"
