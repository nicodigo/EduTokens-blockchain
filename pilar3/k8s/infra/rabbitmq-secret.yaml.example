# RabbitMQ Credentials Secret
# ⚠️  RENOMBRAR a rabbitmq-secret.yaml y completar los valores reales antes de aplicar.
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  namespace: infra
  labels:
    app: rabbitmq
type: Opaque
stringData:
  username: "admin"
  password: "CHANGE_ME_STRONG_PASSWORD"
  # Cookie para el cluster Erlang de RabbitMQ (soluciona bug de permisos con fsGroup)
  erlang-cookie: "CHANGE_ME_RANDOM_STRING_20_CHARS"
