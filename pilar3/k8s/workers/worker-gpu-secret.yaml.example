# Worker GPU Secret — credenciales de conexión AMQPS
# ⚠️  RENOMBRAR a worker-gpu-secret.yaml y completar antes de aplicar.
apiVersion: v1
kind: Secret
metadata:
  name: worker-gpu-secret
  namespace: g-compumundo
  labels:
    app: worker-gpu
type: Opaque
stringData:
  # AMQPS con TLS: los workers validan el certificado contra la CA embebida
  RABBITMQ_URL: "amqps://admin:CHANGE_ME@rabbitmq.edutokens.xyz:5671/"
