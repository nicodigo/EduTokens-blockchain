# =============================================================================
# Environment variables for Pilar 2 services
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets here.
# =============================================================================

# --- NCT (Node Coordinator) ---
# Redis connection URL
# REDIS_URL=redis://redis:6379

# RabbitMQ connection URL
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Number of transactions per block
# BLOCK_SIZE=5

# Seconds before expanding the nonce search space
# BLOCK_TIMEOUT=30

# Proof-of-Work difficulty (number of leading zero nibbles, 1-10)
# DIFFICULTY=4

# Initial nonce search space size
# NONCE_SPACE=1000000000

# HTTP port for health/transaction API
# PORT=8080

# Log file path inside the container (empty = stdout only)
# LOG_FILE=/var/log/nct.log

# Ed25519 public key authorised to issue EARN transactions (64 hex chars)
# Leave empty to disable EARN transactions.
# AUTHORITY_PUBKEY=

# Heartbeat timeout in seconds (workers not seen in this window are considered dead)
# HEARTBEAT_TIMEOUT=15.0

# Rate limit for POST /transaction (requests per minute)
# RATE_LIMIT=100/minute

# --- Pool ---
# RabbitMQ connection URL
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Unique pool identifier
# POOL_ID=pool-a

# Fallback worker count (used when no heartbeat data is available yet)
# POOL_WORKER_COUNT=2

# HTTP port for health endpoint
# HEALTH_PORT=8090

# Log file path inside the container
# LOG_FILE=/var/log/pool-a.log

# --- Worker ---
# RabbitMQ connection URL
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Path to the mining binary or command (CPU fallback in Docker)
# MINER_BINARY=python3 /app/miner/cpu_miner.py

# Unique worker identifier
# WORKER_ID=worker-a1

# Pool this worker belongs to (empty = solo mining)
# POOL_ID=pool-a

# Seconds between heartbeat messages
# HEARTBEAT_INTERVAL=5

# HTTP port for health/status endpoint
# HEALTH_PORT=8081

# Log file path inside the container
# LOG_FILE=/var/log/worker-a1.log
